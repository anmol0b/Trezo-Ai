# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ─── Solana ───────────────────────────────────────────────────────────────────
# Get a Helius devnet API key at https://dev.helius.xyz
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
HELIUS_API_KEY=YOUR_HELIUS_KEY
HELIUS_WS_URL=wss://devnet.helius-rpc.com

# Your Anchor program ID (from anchor deploy output)
PROGRAM_ID=YOUR_PROGRAM_ID_HERE

# Agent keypair — JSON array from: solana-keygen new --outfile agent-keypair.json
# Then: cat agent-keypair.json
AGENT_KEYPAIR=[1,2,3,4,5...]

# Company ID used for PDA derivation
COMPANY_ID=koshai-demo

# ─── AI ───────────────────────────────────────────────────────────────────────
# Set ONE of these — Anthropic preferred, OpenAI as fallback
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── Vector DB (optional — RAG works without it using pseudo-embeddings) ──────
PINECONE_API_KEY=YOUR_PINECONE_KEY
PINECONE_INDEX=koshai-invoices

# ─── Dodo Payments ────────────────────────────────────────────────────────────
DODO_API_KEY=YOUR_DODO_KEY
DODO_SANDBOX=true
DODO_API_URL=https://test.dodopayments.com

# Fiat conversion config (used by oracle-watcher job)
FIAT_CONVERSION_AMOUNT_USDC=1000
FIAT_TARGET_IBAN=GB82WEST12345698765432
FIAT_TARGET_CURRENCY=USD

# ─── Jobs ─────────────────────────────────────────────────────────────────────
YIELD_IDLE_THRESHOLD_USDC=5000
YIELD_POLL_INTERVAL_MS=900000
PYTH_RATE_TRIGGER=1.002