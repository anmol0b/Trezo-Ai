{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "NEXT_PUBLIC_SUPABASE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "NEXT_PUBLIC_SOLANA_RPC_URL",
    "BACKEND_API_URL",
    "COMPANY_ID",
    "NEXT_PUBLIC_TREASURY_PDA",
    "NEXT_PUBLIC_DEPT_PDA",
    "NEXT_PUBLIC_RECIPIENT_WALLET",
    "SUPABASE_SECRET_KEY",
    "SUPABASE_URL",
    "NEXT_PUBLIC_DASHBOARD_API_URL",
    "NEXT_PUBLIC_YIELD_API_URL",
    "NEXT_PUBLIC_DEPARTMENT_API_URL",
    "NEXT_PUBLIC_SETTINGS_API_URL",
    "NEXT_PUBLIC_PROPOSAL_API_URL",
    "NEXT_PUBLIC_INVOICES_API_URL",
    "NEXT_PUBLIC_AUDIT_API_URL",
    "NEXT_PUBLIC_COINFLOW_ENV",
    "NEXT_PUBLIC_COINFLOW_MERCHANT_ID",
    "BACKEND_API_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}